{
  "name": "flash-promoter",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,desktop -c green,blue \"npm run dev:api\" \"npm run dev:desktop\"",
    "dev:api": "tsx apps/local-api/src/server.ts",
    "dev:desktop": "npm run dev --workspace @flash-promoter/desktop",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "test:acceptance": "node scripts/acceptance-test.mjs"
  },
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "concurrently": "^10.0.0",
    "typescript": "^5.9.3"
  }
}
